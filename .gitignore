# Ignore everything by default.
*

# Keep this file tracked.
!/.gitignore

# Only manage source-code areas.
!/language_recognition_system/
!/language_recognition_system/**
!/skills/
!/skills/**

# Ignore generated artifacts inside managed code directories.
language_recognition_system/checkpoints/
language_recognition_system/**/__pycache__/
language_recognition_system/**/*.py[cod]
language_recognition_system/.pytest_cache/
language_recognition_system/.mypy_cache/
language_recognition_system/.venv/
language_recognition_system/venv/

skills/**/__pycache__/
skills/**/*.py[cod]
skills/.pytest_cache/
skills/.mypy_cache/
skills/.venv/
skills/venv/
